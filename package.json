{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "dev": "pnpm --parallel --filter @workspace/api-server --filter @workspace/textile-erp run dev",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:web": "pnpm --filter @workspace/textile-erp run dev",
    "dev:db": "docker compose up -d postgres",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:push:force": "pnpm --filter @workspace/db run push-force",
    "db:push:prod": "node ./lib/db/run-drizzle.mjs push --config ./lib/db/drizzle.config.ts",
    "seed": "pnpm --filter @workspace/scripts run seed",
    "test": "pnpm --filter @workspace/api-server run test",
    "test:auth": "pnpm --filter @workspace/api-server exec sh -lc 'DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roll_manager node --import tsx --test ./src/modules/auth/auth.service.test.ts ./test/auth.routes.integration.test.ts'",
    "test:unit": "pnpm --filter @workspace/api-server run test:unit",
    "test:integration": "pnpm --filter @workspace/api-server run test:integration",
    "test:smoke:api": "pnpm --filter @workspace/api-server run test:smoke",
    "verify:api": "pnpm exec tsc -p artifacts/api-server/tsconfig.json --noEmit && pnpm run test:auth",
    "smoke:test": "pnpm --filter @workspace/scripts run smoke",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "typecheck:libs": "tsc --build --force",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
