# Required: database
POSTGRES_DB=roll_manager
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-strong-db-password
DATABASE_URL=postgresql://postgres:replace-with-strong-db-password@postgres:5432/roll_manager

# Required: app + auth
APP_URL=https://your-domain.example
JWT_SECRET=replace-with-long-random-secret
JWT_ISSUER=fabric-flow
JWT_AUDIENCE=
JWT_CLOCK_TOLERANCE_SEC=15
AUTH_SESSION_MODE=hybrid
AUTH_COOKIE_NAME=textile_erp_session
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
SUPER_ADMIN_EMAIL=superadmin@your-domain.example
SUPER_ADMIN_PASSWORD=replace-with-strong-password
SUPER_ADMIN_NAME=مدير المنصة
RUN_DB_BOOTSTRAP=false

# Required for cookie/hybrid auth across domains
CORS_ALLOWED_ORIGINS=https://your-domain.example
TRUST_PROXY=true

# Frontend build-time settings
VITE_API_URL=https://api.your-domain.example
VITE_AUTH_SESSION_MODE=hybrid
VITE_AUTH_STORAGE=session
VITE_PRICING_USD_RATE=50

# Optional: logging/alerts
LOG_LEVEL=info
ALERT_WEBHOOK_URL=

# Required if STORAGE_PROVIDER=s3
STORAGE_PROVIDER=s3
UPLOADS_DIR=uploads
UPLOADS_PUBLIC_BASE_URL=https://cdn.your-domain.example
S3_ENDPOINT=https://your-r2-or-s3-endpoint
S3_REGION=auto
S3_BUCKET=roll-manager
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_PUBLIC_BASE_URL=https://cdn.your-domain.example
S3_FORCE_PATH_STYLE=false

# Optional billing defaults
PRICING_GOOGLE_USD_RATE=50
PAYMENT_CURRENCY=EGP
INSTAPAY_ACCOUNT=instapay@textileerp
INSTAPAY_NOTE=حوّل المبلغ الكامل ثم ارفع إثبات العملية.
VODAFONE_CASH_NUMBER=01000000000
VODAFONE_CASH_NOTE=استخدم الرقم المخصص للشركة ثم أرفق صورة واضحة لإثبات الدفع.

# Stripe (required only if Stripe billing is enabled)
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_BASIC_MONTHLY=price_replace_basic_monthly
STRIPE_PRICE_BASIC_YEARLY=price_replace_basic_yearly
STRIPE_PRICE_PRO_MONTHLY=price_replace_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_replace_pro_yearly

# Backup container settings (docker-compose.prod.yml)
BACKUP_KEEP_DAYS=7
BACKUP_INTERVAL_HOURS=24
