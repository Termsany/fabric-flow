# Required (local dev defaults)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/roll_manager
PORT=8080
APP_URL=http://localhost:3000
BASE_PATH=/
VITE_API_URL=http://localhost:8080

# Auth/session
JWT_SECRET=replace-with-long-random-secret
JWT_ISSUER=fabric-flow
JWT_AUDIENCE=
JWT_CLOCK_TOLERANCE_SEC=15
AUTH_SESSION_MODE=bearer
AUTH_COOKIE_NAME=textile_erp_session
AUTH_COOKIE_SAMESITE=lax
AUTH_COOKIE_DOMAIN=
AUTH_COOKIE_PATH=/
VITE_AUTH_SESSION_MODE=bearer
VITE_AUTH_STORAGE=local

# Bootstrap super admin (optional but recommended for first login)
SUPER_ADMIN_EMAIL=superadmin@example.com
SUPER_ADMIN_PASSWORD=replace-with-strong-password
SUPER_ADMIN_NAME=مدير المنصة

# CORS/proxy (set APP_URL and this if using cookie/hybrid auth)
CORS_ALLOWED_ORIGINS=http://localhost:3000
TRUST_PROXY=false

# Logging & alerts
LOG_LEVEL=info
ALERT_WEBHOOK_URL=

# Storage (local by default)
STORAGE_PROVIDER=local
UPLOADS_DIR=uploads
UPLOADS_PUBLIC_BASE_URL=
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=
S3_FORCE_PATH_STYLE=false

# Billing (optional defaults)
PRICING_GOOGLE_USD_RATE=50
PAYMENT_CURRENCY=EGP
INSTAPAY_ACCOUNT=instapay@textileerp
INSTAPAY_NOTE=حوّل المبلغ الكامل ثم ارفع إثبات العملية.
VODAFONE_CASH_NUMBER=01000000000
VODAFONE_CASH_NOTE=استخدم الرقم المخصص للشركة ثم أرفق صورة واضحة لإثبات الدفع.

# Stripe (required only if Stripe billing is enabled)
STRIPE_SECRET_KEY=sk_test_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
STRIPE_PRICE_BASIC_MONTHLY=price_replace_basic_monthly
STRIPE_PRICE_BASIC_YEARLY=price_replace_basic_yearly
STRIPE_PRICE_PRO_MONTHLY=price_replace_pro_monthly
STRIPE_PRICE_PRO_YEARLY=price_replace_pro_yearly

# Frontend display helpers (optional)
VITE_PRICING_USD_RATE=50
