{
  "family": "textile-erp-backend",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::<ACCOUNT_ID>:role/textile-erp-backend-task-role",
  "containerDefinitions": [
    {
      "name": "backend",
      "image": "<BACKEND_IMAGE>",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "NODE_ENV", "value": "production" },
        { "name": "PORT", "value": "8080" },
        { "name": "TRUST_PROXY", "value": "true" },
        { "name": "RUN_DB_BOOTSTRAP", "value": "false" }
      ],
      "secrets": [
        { "name": "DATABASE_URL", "valueFrom": "<DATABASE_URL_SECRET_ARN>" },
        { "name": "APP_URL", "valueFrom": "<APP_URL_SECRET_ARN>" },
        { "name": "JWT_SECRET", "valueFrom": "<JWT_SECRET_SECRET_ARN>" },
        { "name": "SUPER_ADMIN_EMAIL", "valueFrom": "<SUPER_ADMIN_EMAIL_SECRET_ARN>" },
        { "name": "SUPER_ADMIN_PASSWORD", "valueFrom": "<SUPER_ADMIN_PASSWORD_SECRET_ARN>" },
        { "name": "SUPER_ADMIN_NAME", "valueFrom": "<SUPER_ADMIN_NAME_SECRET_ARN>" },
        { "name": "CORS_ALLOWED_ORIGINS", "valueFrom": "<CORS_ALLOWED_ORIGINS_SECRET_ARN>" },
        { "name": "LOG_LEVEL", "valueFrom": "<LOG_LEVEL_SECRET_ARN>" },
        { "name": "ALERT_WEBHOOK_URL", "valueFrom": "<ALERT_WEBHOOK_URL_SECRET_ARN>" },
        { "name": "STORAGE_PROVIDER", "valueFrom": "<STORAGE_PROVIDER_SECRET_ARN>" },
        { "name": "UPLOADS_PUBLIC_BASE_URL", "valueFrom": "<UPLOADS_PUBLIC_BASE_URL_SECRET_ARN>" },
        { "name": "S3_ENDPOINT", "valueFrom": "<S3_ENDPOINT_SECRET_ARN>" },
        { "name": "S3_REGION", "valueFrom": "<S3_REGION_SECRET_ARN>" },
        { "name": "S3_BUCKET", "valueFrom": "<S3_BUCKET_SECRET_ARN>" },
        { "name": "S3_ACCESS_KEY_ID", "valueFrom": "<S3_ACCESS_KEY_ID_SECRET_ARN>" },
        { "name": "S3_SECRET_ACCESS_KEY", "valueFrom": "<S3_SECRET_ACCESS_KEY_SECRET_ARN>" },
        { "name": "S3_PUBLIC_BASE_URL", "valueFrom": "<S3_PUBLIC_BASE_URL_SECRET_ARN>" },
        { "name": "S3_FORCE_PATH_STYLE", "valueFrom": "<S3_FORCE_PATH_STYLE_SECRET_ARN>" },
        { "name": "PRICING_GOOGLE_USD_RATE", "valueFrom": "<PRICING_GOOGLE_USD_RATE_SECRET_ARN>" },
        { "name": "STRIPE_SECRET_KEY", "valueFrom": "<STRIPE_SECRET_KEY_SECRET_ARN>" },
        { "name": "STRIPE_WEBHOOK_SECRET", "valueFrom": "<STRIPE_WEBHOOK_SECRET_SECRET_ARN>" },
        { "name": "STRIPE_PRICE_BASIC_MONTHLY", "valueFrom": "<STRIPE_PRICE_BASIC_MONTHLY_SECRET_ARN>" },
        { "name": "STRIPE_PRICE_BASIC_YEARLY", "valueFrom": "<STRIPE_PRICE_BASIC_YEARLY_SECRET_ARN>" },
        { "name": "STRIPE_PRICE_PRO_MONTHLY", "valueFrom": "<STRIPE_PRICE_PRO_MONTHLY_SECRET_ARN>" },
        { "name": "STRIPE_PRICE_PRO_YEARLY", "valueFrom": "<STRIPE_PRICE_PRO_YEARLY_SECRET_ARN>" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/textile-erp-backend",
          "awslogs-region": "<AWS_REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "healthCheck": {
        "command": ["CMD-SHELL", "node -e \"fetch('http://127.0.0.1:8080/api/health').then(r=>process.exit(r.ok?0:1)).catch(()=>process.exit(1))\""],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 30
      }
    }
  ]
}
